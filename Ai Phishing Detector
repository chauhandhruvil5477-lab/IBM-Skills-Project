from flask import Flask, render_template_string, request
import re
from sklearn.ensemble import RandomForestClassifier

app = Flask(__name__)

# -----------------------------
# SIMPLE AI MODEL
# -----------------------------
X = [
    [10,0,0,0,1,0,0],
    [80,2,1,3,0,1,4],
    [50,0,1,1,1,0,0],
    [95,3,2,4,0,1,5],
    [20,0,0,0,1,0,0],
    [85,2,2,3,0,1,3],
]

y = [0,1,0,1,0,1]

model = RandomForestClassifier(n_estimators=100, random_state=42)
model.fit(X, y)

history = []

# -----------------------------
# FEATURE EXTRACTION
# -----------------------------
def extract_features(url):
    url_length = len(url)
    at_count = url.count('@')
    dash_count = url.count('-')
    slash_count = url.count('/')

    https_flag = 1 if url.lower().startswith("https://") else 0

    ip = re.findall(r'(?:\d{1,3}\.){3}\d{1,3}', url)
    ip_flag = 1 if ip else 0

    suspicious_words = [
        "login","verify","secure",
        "account","bank","update",
        "paypal","signin"
    ]

    keyword_score = 0
    for word in suspicious_words:
        if word in url.lower():
            keyword_score += 1

    return [
        url_length,
        at_count,
        dash_count,
        slash_count,
        https_flag,
        ip_flag,
        keyword_score
    ]

# -----------------------------
# RISK CALCULATION
# -----------------------------
def calculate_risk(features, prob):
    rule_risk = 0

    if features[0] > 75: rule_risk += 20
    if features[1] > 0: rule_risk += 15
    if features[2] > 1: rule_risk += 10
    if features[4] == 0: rule_risk += 25
    if features[5] == 1: rule_risk += 30
    if features[6] > 2: rule_risk += 20

    risk = (rule_risk + prob * 100) / 2
    return round(min(risk, 100), 2)

# -----------------------------
# HTML TEMPLATE
# -----------------------------
HTML = """
