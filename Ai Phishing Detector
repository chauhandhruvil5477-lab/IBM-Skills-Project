# -----------------------------
# ROUTES
# -----------------------------
@app.route('/')
def home():
    total = len(history)
    safe_count = len([x for x in history if x["result"] == "SAFE"])
    phishing_count = len([x for x in history if x["result"] == "PHISHING"])

    return render_template_string(
        HTML,
        total=total,
        safe_count=safe_count,
        phishing_count=phishing_count,
        history=history
    )

@app.route('/check', methods=['POST'])
def check():
    url = request.form['url']
    features = extract_features(url)

    prob = model.predict_proba([features])[0][1]

    # 🔥 IMPORTANT: lower threshold for phishing detection
    if prob > 0.4:
        pred = 1
    else:
        pred = 0

    # extra safety: rule-based override
    if features[5] == 1 or features[4] == 0 or features[6] > 2:
        pred = 1

    risk = calculate_risk(features, prob)

    if pred == 0:
        result = "SAFE"
        color = "safe"
    else:
        result = "PHISHING"
        color = "phishing"

    history.append({
        "url": url,
        "result": result,
        "risk": risk
    })

    total = len(history)
    safe_count = len([x for x in history if x["result"] == "SAFE"])
    phishing_count = len([x for x in history if x["result"] == "PHISHING"])

    return render_template_string(
        HTML,
        result=result,
        color=color,
        url=url,
        prob=round(prob*100,2),
        risk=risk,
        length=features[0],
        at=features[1],
        dash=features[2],
        https="Yes" if features[4] else "No",
        ip="Yes" if features[5] else "No",
        keyword=features[6],
        history=history,
        total=total,
        safe_count=safe_count,
        phishing_count=phishing_count
    )

# -----------------------------
# RUN APP
# -----------------------------
if __name__ == "__main__":
    app.run(debug=True)
